# Go URL Alias Service - Environment Variables
# Copy this file to .env and fill in the values.

# Connection string for Cosmos DB (emulator or real instance).
# Required for production. Leave empty for local dev to use the in-memory store.
# For local development with the Cosmos DB Emulator, use:
# AccountEndpoint=https://localhost:8081/;AccountKey=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
COSMOS_CONNECTION_STRING=

# Set to "true" to enable mock authentication and bypass SWA Entra ID.
# Optional. Default: false
DEV_MODE=false

# Default mock user email when DEV_MODE is enabled and no mock headers are set.
# Optional. Default: dev@localhost
DEV_USER_EMAIL=dev@localhost

# Default mock user roles (comma-separated) when DEV_MODE is enabled and no mock headers are set.
# Optional. Default: User
DEV_USER_ROLES=User
