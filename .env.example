# Go URL Alias Service - Environment Variables
# Copy this file to .env and fill in the values.

# ── Auth Mode ────────────────────────────────────────────────────────
# Selects the active authentication strategy.
# Required. Must be one of: corporate, public, dev
AUTH_MODE=dev

# ── Corporate Lock ───────────────────────────────────────────────────
# When "true", prevents the API from starting in any mode other than "corporate".
# Safety mechanism for corporate deployments.
# Optional. Default: false
CORPORATE_LOCK=false

# ── Public Auth Providers ────────────────────────────────────────────
# Comma-separated list of identity providers for public mode.
# Known providers: aad, google, github, twitter
# Optional. Default: google
PUBLIC_AUTH_PROVIDERS=google

# ── Cosmos DB ────────────────────────────────────────────────────────
# Connection string for Cosmos DB (emulator or real instance).
# Required for corporate and public modes. Optional for dev mode (uses in-memory store).
COSMOS_CONNECTION_STRING=

# ── Dev Mode Settings ────────────────────────────────────────────────
# Default mock user email when AUTH_MODE=dev and no mock headers are set.
# Optional. Default: dev@localhost
DEV_USER_EMAIL=dev@localhost

# Default mock user roles (comma-separated) when AUTH_MODE=dev and no mock headers are set.
# Optional. Default: User
DEV_USER_ROLES=User
